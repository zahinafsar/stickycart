// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Brand {
  id        String   @id @default(cuid())
  shop      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referralConfig ReferralConfig?
  customers      Customer[]
}

model Customer {
  id                String   @id @default(cuid())
  brandId           String
  brand             Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  email             String
  shopifyCustomerId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  asReferrer Referrer?
  asReferee  Referee?

  @@unique([brandId, email])
  @@index([brandId, shopifyCustomerId])
}

model ReferralConfig {
  id                  String   @id @default(cuid())
  brandId             String   @unique
  brand               Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  enabled             Boolean  @default(true)
  refereeDiscount     Json     @default("{\"type\":\"PERCENT\",\"amount\":10,\"validity_seconds\":2592000,\"max_uses\":1,\"min_order_amount\":0}")
  referrerDiscount    Json     @default("{\"type\":\"PERCENT\",\"amount\":10,\"validity_seconds\":2592000,\"max_uses\":1,\"min_order_amount\":0}")
  maxReferralsPerUser Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  referrers Referrer[]
  referees  Referee[]
  referrals Referral[]
}

model Referrer {
  id               String         @id @default(cuid())
  referralConfigId String
  referralConfig   ReferralConfig @relation(fields: [referralConfigId], references: [id], onDelete: Cascade)
  customerId       String         @unique
  customer         Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  code             String         @unique
  welcomeEmailedAt DateTime?
  createdAt        DateTime       @default(now())

  referrals Referral[]
}

model Referee {
  id               String         @id @default(cuid())
  referralConfigId String
  referralConfig   ReferralConfig @relation(fields: [referralConfigId], references: [id], onDelete: Cascade)
  customerId       String         @unique
  customer         Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  referral Referral?
}

enum ReferralStatus {
  CLAIMED
  CONVERTED
  REJECTED_SELF
  REJECTED_EXISTING
  REJECTED_FRAUD
  EXPIRED
}

model Referral {
  id                 String         @id @default(cuid())
  referralConfigId   String
  referralConfig     ReferralConfig @relation(fields: [referralConfigId], references: [id], onDelete: Cascade)
  referrerId         String
  referrer           Referrer       @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  refereeId          String?        @unique
  referee            Referee?       @relation(fields: [refereeId], references: [id], onDelete: SetNull)
  refereeDiscountId  String?        @unique
  refereeDiscount    Discount?      @relation("RefereeDiscount", fields: [refereeDiscountId], references: [id])
  referrerDiscountId String?        @unique
  referrerDiscount   Discount?      @relation("ReferrerDiscount", fields: [referrerDiscountId], references: [id])
  status             ReferralStatus @default(CLAIMED)
  orderId            String?
  createdAt          DateTime       @default(now())
  convertedAt        DateTime?

  @@index([referralConfigId, status])
  @@index([referrerId, status])
}

model Discount {
  id            String    @id @default(cuid())
  shopifyCodeId String
  code          String    @unique
  emailedAt     DateTime?
  createdAt     DateTime  @default(now())

  refereeFor  Referral? @relation("RefereeDiscount")
  referrerFor Referral? @relation("ReferrerDiscount")
}

model ProcessedWebhook {
  id         String   @id
  topic      String
  shop       String
  apiVersion String?
  payload    Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([shop, topic, createdAt])
}
